# Vitalytics backend environment variables
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# ── Anthropic API ────────────────────────────────────────────────────────────
# Get your key at https://console.anthropic.com (billed separately from Claude Pro)
# If you don't have a key yet, set DEMO_MOCK=true below — the full pipeline
# will still run using pre-baked agent responses.
ANTHROPIC_API_KEY=sk-ant-...

# ── CORS ─────────────────────────────────────────────────────────────────────
# URL of the Next.js frontend (must match exactly — no trailing slash)
# Local dev:
FRONTEND_URL=http://localhost:3000
# Vercel production (set this in Vercel env vars instead of .env):
# FRONTEND_URL=https://your-project.vercel.app

# ── Demo / Mock mode ─────────────────────────────────────────────────────────
# Set to "true" to bypass the Anthropic API entirely.
# The agent will return realistic pre-baked responses so you can run the full
# 5-step pipeline (Upload → Profile → Hygiene → Generate → Verify) without a key.
# Remove this line (or set to "false") once you have a real API key.
DEMO_MOCK=true
